# ─────────────────────────────────────────────────────────────────────────────
# Enroll consumer app — environment variables
#
# Copy this file to .env and fill in the values.
# Never commit .env to source control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ─────────────────────────────────────────────────────────────────

# Hosted project (production / staging)
#   URL and anon key: Supabase dashboard → Project Settings → API
# VITE_SUPABASE_URL=https://<project-ref>.supabase.co
# VITE_SUPABASE_ANON_KEY=<anon-key>

# Local development (after running `supabase start`)
#   URL is always http://127.0.0.1:54321
#   Anon key is printed by `supabase start`, or run `supabase status`
# VITE_SUPABASE_URL=http://127.0.0.1:54321
# VITE_SUPABASE_ANON_KEY=<local-anon-key>

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── Business slug ─────────────────────────────────────────────────────────────
# Slug of the business this app instance is scoped to.
# Seed data uses 'corner-cup' — change for a real deployment.
VITE_BUSINESS_SLUG=corner-cup
